# ==============================================================================
# Environment Configuration (.env.example)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Local Configuration Block
# ------------------------------------------------------------------------------
# Use this connection string for local development with a native PostgreSQL 
# server running on your machine.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL="postgresql://postgres:password@localhost:5432/medcamp"


# ------------------------------------------------------------------------------
# 2. Production AWS RDS Configuration Block
# ------------------------------------------------------------------------------
# Use this block when deploying to production with AWS RDS. 
# Ensure this environment variable is set securely in your server environment 
# (e.g., Vercel or AWS Secrets Manager) and never leaked to the client code.
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:PORT/DATABASE?schema=public
# DATABASE_URL="postgresql://medcamp_user:secure_password_here@medcamp-db.c3x9example.us-east-1.rds.amazonaws.com:5432/medcamp_prod?schema=public"
